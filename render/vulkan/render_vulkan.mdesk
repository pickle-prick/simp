//- rjf: stack table

@table(name, name_lower, type, default)
R_VK_StackTable:
{
  //- k: parents
  { Cmd                             cmd                       `VkCommandBuffer`                0                                }
}

//- rjf: declaring stack node types

@gen
{
  @expand(R_VK_StackTable a) `typedef struct R_VK_$(a.name)Node R_VK_$(a.name)Node; struct R_VK_$(a.name)Node{R_VK_$(a.name)Node *next; $(a.type) v;};`
}

//- rjf: declaring all default stack tops

@gen
{
  `#define R_VK_DeclStackNils \\`;
  `struct\\`;
  `{\\`;
    @expand(R_VK_StackTable a) `R_VK_$(a.name)Node $(a.name_lower)_nil_stack_top;\\`;
    `}`;
}

//- rjf: initializing all default stack tops

@gen
{
  `#define R_VK_InitStackNils(state) \\`;
  @expand(R_VK_StackTable a) `state->$(a.name_lower)_nil_stack_top.v = $(a.default);\\`;
  ``;
}

//- rjf: declaring all stack nodes & free lists

@gen
{
  `#define R_VK_DeclStacks \\`;
  `struct\\`;
  `{\\`;
    @expand(R_VK_StackTable a) `struct { R_VK_$(a.name)Node *top; $(a.type) bottom_val; R_VK_$(a.name)Node *free; B32 auto_pop; } $(a.name_lower)_stack;\\`;
    `}`;
}

//- rjf: initing all stack nodes

@gen
{
  `#define R_VK_InitStacks(state) \\`;
  @expand(R_VK_StackTable a) `state->$(a.name_lower)_stack.top = &state->$(a.name_lower)_nil_stack_top; state->$(a.name_lower)_stack.bottom_val = $(a.default); state->$(a.name_lower)_stack.free = 0; state->$(a.name_lower)_stack.auto_pop = 0;\\`;
  ``;
}

//- rjf: auto-popping all stacks

@gen
{
  `#define R_VK_AutoPopStacks(state) \\`
  @expand(R_VK_StackTable a)
    `if(state->$(a.name_lower)_stack.auto_pop) { r_vk_pop_$(a.name_lower)(); state->$(a.name_lower)_stack.auto_pop = 0; }\\`;
  ``; }

//- rjf: decls for the stack function operation headers

@gen
{
  @expand(R_VK_StackTable a)
    `internal $(a.type) $(=>35) r_vk_top_$(a.name_lower)(void);`
    @expand(R_VK_StackTable a)
    `internal $(a.type) $(=>35) r_vk_bottom_$(a.name_lower)(void);`
    @expand(R_VK_StackTable a)
    `internal $(a.type) $(=>35) r_vk_push_$(a.name_lower)($(a.type) v);`
    @expand(R_VK_StackTable a)
    `internal $(a.type) $(=>35) r_vk_pop_$(a.name_lower)(void);`
    @expand(R_VK_StackTable a)
    `internal $(a.type) $(=>35) r_vk_set_next_$(a.name_lower)($(a.type) v);`
}

//- rjf: defer-loop helpers

@gen @c_file
{
  `#if 1`;
  @expand(R_VK_StackTable a)
    `#define R_VK_$(a.name)_Scope(v) DeferLoop(r_vk_push_$(a.name_lower)(v), r_vk_pop_$(a.name_lower)())`
  `#endif`;
}

//- rjf: decls for the stack operation implementations

@gen @c_file
{
  @expand(R_VK_StackTable a)
    `internal $(a.type) r_vk_top_$(a.name_lower)(void) { R_VK_StackTopImpl(r_vk_state, $(a.name), $(a.name_lower)) }`;
  @expand(R_VK_StackTable a)
    `internal $(a.type) r_vk_bottom_$(a.name_lower)(void) { R_VK_StackBottomImpl(r_vk_state, $(a.name), $(a.name_lower)) }`;
  @expand(R_VK_StackTable a)
    `internal $(a.type) r_vk_push_$(a.name_lower)($(a.type) v) { R_VK_StackPushImpl(r_vk_state, $(a.name), $(a.name_lower), $(a.type), v) }`;
  @expand(R_VK_StackTable a)
    `internal $(a.type) r_vk_pop_$(a.name_lower)(void) { R_VK_StackPopImpl(r_vk_state, $(a.name), $(a.name_lower)) }`;
  @expand(R_VK_StackTable a)
    `internal $(a.type) r_vk_set_next_$(a.name_lower)($(a.type) v) { R_VK_StackSetNextImpl(r_vk_state, $(a.name), $(a.name_lower), $(a.type), v) }`;
}
